{
  "name": "@mariozechner/jot",
  "version": "0.1.2",
  "bin": {
    "jot": "cli/jot.mjs"
  },
  "files": [
    "dist",
    "public",
    "cli"
  ],
  "description": "Minimal self-hosted markdown editor with inline comment threads",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc --noEmit && esbuild src/server.ts --bundle --platform=node --format=cjs --target=node20 --outfile=dist/server.js --external:better-sqlite3",
    "typecheck": "tsc --noEmit",
    "start": "node dist/server.js"
  },
  "dependencies": {
    "articulated": "^1.3.1",
    "better-sqlite3": "^12.9.0",
    "diff": "^9.0.0",
    "express": "^5.1.0",
    "highlight.js": "^11.11.1",
    "marked": "^16.4.1",
    "mermaid": "^11.14.0",
    "sanitize-html": "^2.17.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/diff": "^7.0.2",
    "@types/express": "^5.0.3",
    "@types/node": "^24.6.1",
    "@types/sanitize-html": "^2.16.0",
    "@types/ws": "^8.18.1",
    "esbuild": "^0.27.4",
    "tsx": "^4.20.5",
    "typescript": "^5.9.3"
  }
}
